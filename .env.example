# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Defaults to the production ID in src/lib/analytics.ts if unset.
# To disable analytics locally, copy to .env.local and set this to an empty/invalid value
# (anything not starting with "G-"), e.g.: VITE_GA_MEASUREMENT_ID=disabled
VITE_GA_MEASUREMENT_ID=
